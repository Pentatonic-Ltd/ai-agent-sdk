{
  "name": "@pentatonic-ai/agent-events",
  "version": "0.3.0-beta.3",
  "description": "LLM observability SDK — track token usage, tool calls, and conversations via Pentatonic TES",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agent-events": "./bin/cli.js"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "build.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "node build.js",
    "build": "node build.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.cjs",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.cjs --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "llm",
    "observability",
    "ai",
    "openai",
    "anthropic",
    "pentatonic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pentatonic-Ltd/ai-events-sdk.git"
  },
  "dependencies": {
    "esbuild": "^0.20.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  }
}
